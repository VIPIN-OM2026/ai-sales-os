# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=https://vipin-om2026.github.io

# ─── Database (Neon PostgreSQL — free tier) ───────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:<password>@ep-solitary-resonance-aqtlt2q8.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=generate_random_32+_chars_here
JWT_REFRESH_SECRET=generate_different_random_32+_chars_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Redis (Upstash — free tier) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://immense-finch-141342.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your_token_here>

# ─── AI ──────────────────────────────────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── WhatsApp (Meta Cloud API — free) ────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
